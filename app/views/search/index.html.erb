<% content_for(:title) { "Search — Pact" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Search Results</h1>
    <% if @query.present? %>
      <p class="mt-1 text-sm text-gray-500">Showing results for "<strong><%= @query %></strong>"</p>
    <% end %>
  </div>

  <% if @query.blank? %>
    <div class="bg-white rounded-xl shadow-sm p-12 text-center">
      <svg class="h-12 w-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <h2 class="text-lg font-medium text-gray-900">Enter a search query</h2>
      <p class="mt-1 text-sm text-gray-500">Search across your contacts and documents.</p>
    </div>
  <% elsif @contacts.empty? && @documents.empty? %>
    <div class="bg-white rounded-xl shadow-sm p-12 text-center">
      <svg class="h-12 w-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <h2 class="text-lg font-medium text-gray-900">No results found</h2>
      <p class="mt-1 text-sm text-gray-500">Try a different search term or check your spelling.</p>
    </div>
  <% else %>
    <% if @contacts.any? %>
      <div class="mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Contacts</h2>
          <span class="text-xs text-gray-400"><%= @contacts.size %> result<%= @contacts.size == 1 ? '' : 's' %></span>
        </div>
        <div class="bg-white rounded-xl shadow-sm divide-y divide-gray-100">
          <% @contacts.each do |contact| %>
            <%= link_to contact_path(contact), class: "block px-5 py-4 hover:bg-gray-50 transition-colors" do %>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= contact.full_name %></p>
                  <p class="text-sm text-gray-500"><%= contact.email %></p>
                </div>
                <% if contact.company.present? %>
                  <span class="text-xs text-gray-400"><%= contact.company %></span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @documents.any? %>
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Documents</h2>
          <span class="text-xs text-gray-400"><%= @documents.size %> result<%= @documents.size == 1 ? '' : 's' %></span>
        </div>
        <div class="bg-white rounded-xl shadow-sm divide-y divide-gray-100">
          <% @documents.each do |document| %>
            <%= link_to document_path(document), class: "block px-5 py-4 hover:bg-gray-50 transition-colors" do %>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= document.name %></p>
                  <p class="text-sm text-gray-500"><%= document.file_type_category.capitalize %></p>
                </div>
                <span class="text-xs text-gray-400"><%= document.formatted_file_size %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
