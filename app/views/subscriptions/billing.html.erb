<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <% if params[:upgraded] %>
    <div class="mb-6 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg p-4 flex items-center gap-3">
      <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm text-green-800 dark:text-green-300">Your subscription is now active. Thanks for upgrading!</p>
    </div>
  <% end %>

  <!-- Current Plan -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-8">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Billing</h1>
        <div class="mt-2 flex items-center gap-3">
          <span class="text-sm text-gray-500 dark:text-gray-400">Current plan:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold
            <%= @organization.pro_plan? ? 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300' :
                @organization.plan == 'starter' ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300' :
                'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300' %>">
            <%= @organization.plan_display_name %>
          </span>
          <% if @organization.subscription_status == "trialing" %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">Trial</span>
          <% elsif @organization.subscription_status == "past_due" %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Payment past due</span>
          <% end %>
        </div>
      </div>
      <% if @organization.stripe_customer_id.present? && current_user.can_manage_users? %>
        <%= link_to billing_portal_path, data: { "turbo-method": "post" },
            class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" do %>
          Manage Subscription
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <% end %>
      <% end %>
    </div>

    <!-- Usage -->
    <% if @organization.pro_plan? %>
      <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <svg class="h-4 w-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Unlimited documents — <span class="font-semibold text-gray-900 dark:text-gray-100"><%= @organization.documents_used_this_month %></span> created this month
        </div>
      </div>
    <% elsif @organization.plan == "starter" %>
      <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
        <div class="flex justify-between text-sm mb-2">
          <span class="text-gray-600 dark:text-gray-400">Documents this month</span>
          <span class="font-semibold text-gray-900 dark:text-gray-100"><%= @organization.documents_used_this_month %> / <%= @organization.document_limit %></span>
        </div>
        <% usage_pct = [(@organization.documents_used_this_month.to_f / @organization.document_limit * 100).round, 100].min %>
        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5">
          <div class="h-2.5 rounded-full transition-all <%= usage_pct >= 90 ? 'bg-red-500' : usage_pct >= 70 ? 'bg-amber-500' : 'bg-blue-600' %>"
               style="width: <%= usage_pct %>%"></div>
        </div>
        <% if usage_pct >= 90 %>
          <p class="mt-2 text-xs text-red-600 dark:text-red-400">You're close to your limit. Upgrade to Pro for unlimited documents.</p>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @organization.needs_subscription? %>
    <!-- New user: pick a plan -->
    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">Choose a plan to get started</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">All plans include a 14-day free trial. You won't be charged until the trial ends.</p>

    <div class="grid md:grid-cols-2 gap-6 max-w-2xl">
      <!-- Starter -->
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-6 flex flex-col">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Starter</h3>
        <div class="mt-3 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-gray-900 dark:text-gray-100">$9</span>
          <span class="text-gray-500">/mo</span>
        </div>
        <p class="mt-1 text-xs text-emerald-600 font-medium">or $7/mo billed annually</p>
        <ul class="mt-6 space-y-3 flex-1 text-sm text-gray-600 dark:text-gray-400">
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> 10 documents per month</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Unlimited contacts</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Priority email support</li>
        </ul>
        <div class="mt-6">
          <%= link_to subscribe_path("starter", interval: "monthly"),
              class: "block text-center px-4 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" do %>
            Start 14-Day Free Trial
          <% end %>
        </div>
      </div>

      <!-- Pro -->
      <div class="rounded-xl border-2 border-blue-600 bg-white dark:bg-gray-800 p-6 flex flex-col relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">Most Popular</span>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Pro</h3>
        <div class="mt-3 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-gray-900 dark:text-gray-100">$19</span>
          <span class="text-gray-500">/mo</span>
        </div>
        <p class="mt-1 text-xs text-emerald-600 font-medium">or $15/mo billed annually</p>
        <ul class="mt-6 space-y-3 flex-1 text-sm text-gray-600 dark:text-gray-400">
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> <strong class="text-gray-900 dark:text-gray-100">Unlimited</strong> documents</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Team member access</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Shared contact book</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Built-in CRM included</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> No per-document fees, ever</li>
        </ul>
        <div class="mt-6">
          <%= link_to subscribe_path("pro", interval: "monthly"),
              class: "block text-center px-4 py-2.5 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors" do %>
            Start 14-Day Free Trial
          <% end %>
        </div>
      </div>
    </div>

  <% elsif @organization.plan == "starter" && current_user.can_manage_users? %>
    <!-- Starter user: show upgrade option -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Need more documents?</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Upgrade to Pro for unlimited documents, team access, and built-in CRM. You'll only pay the prorated difference.</p>
        </div>
        <%= link_to billing_portal_path, data: { "turbo-method": "post" },
            class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shrink-0" do %>
          Upgrade to Pro — $19/mo
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @organization.paid_plan? && @organization.stripe_customer_id.present? && current_user.can_manage_users? %>
    <!-- Cancel / manage -->
    <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Need to cancel or change your plan?
        <%= link_to billing_portal_path, data: { "turbo-method": "post" }, class: "text-blue-600 hover:text-blue-500 font-medium" do %>
          Manage your subscription
        <% end %>
        — you can cancel anytime, switch plans, or update payment details.
      </p>
    </div>
  <% end %>
</div>
