<% content_for :native_signals, native_form_tag %>
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-8 space-y-6" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="space-y-4">
    <div>
      <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">(<%= @minimum_password_length %> characters minimum)</p>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "mt-1 block w-full" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full" %>
    </div>
  </div>

  <div>
    <%= f.submit "Change my password", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer", data: { turbo_submits_with: "Changing..." } %>
  </div>

  <div class="text-center">
    <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
  </div>
<% end %>
