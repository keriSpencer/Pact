<% content_for :native_signals, native_form_tag %>
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8 space-y-6" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-4">
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full" %>
    </div>
  </div>

  <div>
    <%= f.submit "Send me password reset instructions", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer", data: { turbo_submits_with: "Sending..." } %>
  </div>

  <div class="text-center">
    <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
  </div>
<% end %>
