<% content_for :native_signals, native_form_tag %>
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-6", data: native_form_data }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "First name", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-base sm:text-sm" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= f.text_field :last_name, autocomplete: "family-name", placeholder: "Last name", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-base sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.email_field :email, autocomplete: "email", placeholder: "you@company.com", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-base sm:text-sm" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <div data-controller="password-toggle" class="relative">
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full pr-10 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-base sm:text-sm", data: { password_toggle_target: "input" } %>
        <button type="button" data-action="password-toggle#toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" tabindex="-1">
          <svg data-password-toggle-target="icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </button>
      </div>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <div data-controller="password-toggle" class="relative">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full pr-10 rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-base sm:text-sm", data: { password_toggle_target: "input" } %>
        <button type="button" data-action="password-toggle#toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" tabindex="-1">
          <svg data-password-toggle-target="icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%= f.hidden_field :timezone, id: "user_timezone" %>
  <script>document.getElementById("user_timezone").value = Intl.DateTimeFormat().resolvedOptions().timeZone;</script>

  <div>
    <%= f.submit "Create Account", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer", data: native_submit_data.merge(turbo_submits_with: "Creating account...") %>
  </div>

  <div class="text-center">
    <%= link_to "Already have an account? Sign in", new_session_path(resource_name), class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
  </div>
<% end %>
