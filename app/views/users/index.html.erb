<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Team</h1>

  <div class="bg-white rounded-lg shadow">
    <ul class="divide-y divide-gray-200">
      <% @users.each do |user| %>
        <li class="px-6 py-4">
          <%= link_to user_path(user), class: "flex items-center hover:bg-gray-50 -mx-6 -my-4 px-6 py-4" do %>
            <div class="h-10 w-10 rounded-full bg-blue-600 flex items-center justify-center">
              <span class="text-sm font-medium text-white"><%= user.initials %></span>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-900"><%= user.full_name %></p>
              <p class="text-sm text-gray-500"><%= user.email %></p>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
