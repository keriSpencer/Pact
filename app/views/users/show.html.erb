<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-lg shadow-sm">
    <div class="px-6 py-5 border-b border-gray-200">
      <div class="flex items-center">
        <div class="h-12 w-12 rounded-full bg-blue-600 flex items-center justify-center">
          <span class="text-lg font-medium text-white"><%= @user.initials %></span>
        </div>
        <div class="ml-4">
          <h1 class="text-xl font-bold text-gray-900"><%= @user.full_name %></h1>
          <p class="text-sm text-gray-500"><%= @user.email %></p>
        </div>
      </div>
    </div>
    <div class="px-6 py-5 space-y-4">
      <% if @user.title.present? %>
        <div>
          <dt class="text-sm font-medium text-gray-500">Title</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.title %></dd>
        </div>
      <% end %>
      <% if @user.phone.present? %>
        <div>
          <dt class="text-sm font-medium text-gray-500">Phone</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.phone %></dd>
        </div>
      <% end %>
      <div>
        <dt class="text-sm font-medium text-gray-500">Role</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @user.role.humanize %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Member since</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
      </div>
    </div>
    <% if @user == current_user %>
      <div class="px-6 py-4 bg-gray-50 rounded-b-lg">
        <%= link_to "Edit Profile", edit_user_path(@user), class: "text-sm text-blue-600 hover:text-blue-800 font-medium transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
