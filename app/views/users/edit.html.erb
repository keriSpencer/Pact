<% content_for :native_signals, native_form_tag %>
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">Edit Profile</h1>
    </div>
    <%= form_with(model: @user, url: user_path(@user), method: :patch, class: "px-6 py-5 space-y-6") do |form| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-md p-4" role="alert" aria-live="polite">
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-300">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <%= form.label :first_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :first_name, class: "mt-1 block w-full" %>
        </div>
        <div>
          <%= form.label :last_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :last_name, class: "mt-1 block w-full" %>
        </div>
      </div>

      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.email_field :email, class: "mt-1 block w-full" %>
      </div>

      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.text_field :title, class: "mt-1 block w-full" %>
      </div>

      <div>
        <%= form.label :phone, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.telephone_field :phone, class: "mt-1 block w-full" %>
      </div>

      <div class="flex justify-end space-x-3 pt-4">
        <%= link_to "Cancel", user_path(@user), class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" %>
        <%= form.submit "Save Changes", class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 transition-colors cursor-pointer", data: { turbo_submits_with: "Saving..." } %>
      </div>
    <% end %>
  </div>

  <!-- My Signature -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm mt-6">
    <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">My Signature</h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Save your signature for quick signing. Stored securely and encrypted.</p>
    </div>

    <div class="px-6 py-5 space-y-6">
      <!-- Signature -->
      <div>
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Signature</h3>
        <% if current_user.has_saved_signature? %>
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-white">
            <% if current_user.saved_signature.start_with?("data:image") %>
              <img src="<%= current_user.saved_signature %>" class="h-16 mx-auto" alt="Your signature">
            <% else %>
              <p class="text-center text-lg italic" style="font-family: Georgia, serif"><%= current_user.saved_signature %></p>
            <% end %>
          </div>
          <div class="mt-3 flex justify-between items-center">
            <span class="text-xs text-green-600 dark:text-green-400">Signature saved</span>
            <%= link_to "Clear", clear_signature_user_path(current_user),
                  data: { "turbo-method": "delete", turbo_confirm: "Clear your saved signature?" },
                  class: "text-xs text-red-500 hover:text-red-700 transition-colors" %>
          </div>
        <% else %>
          <div data-controller="signature-capture" data-signature-capture-type-value="signature">
            <div class="flex rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600 mb-3">
              <button type="button" data-action="signature-capture#switchToDraw"
                      class="sig-cap-mode-btn flex-1 py-1.5 text-xs font-medium bg-blue-600 text-white transition-colors">Draw</button>
              <button type="button" data-action="signature-capture#switchToType"
                      class="sig-cap-mode-btn flex-1 py-1.5 text-xs font-medium bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 transition-colors">Type</button>
            </div>
            <div data-signature-capture-target="drawArea">
              <canvas data-signature-capture-target="canvas"
                      class="w-full border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg cursor-crosshair"
                      style="height: 120px; background-color: #ffffff; color-scheme: light;"></canvas>
            </div>
            <div data-signature-capture-target="typeArea" class="hidden">
              <input type="text" data-signature-capture-target="typeInput"
                     data-action="input->signature-capture#onTypeInput"
                     class="block w-full text-lg rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 py-2 px-3"
                     style="font-family: Georgia, cursive; font-size: 22px;"
                     placeholder="Type your signature">
            </div>
            <div class="mt-3 flex justify-between">
              <button type="button" data-action="signature-capture#clear"
                      class="text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">Clear</button>
              <button type="button" data-action="signature-capture#save"
                      data-signature-capture-target="saveBtn"
                      data-url="<%= update_signature_user_path(current_user) %>"
                      class="px-4 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">
                Save Signature
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Initials -->
      <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Initials</h3>
        <% if current_user.has_saved_initials? %>
          <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-white">
            <% if current_user.saved_initials.start_with?("data:image") %>
              <img src="<%= current_user.saved_initials %>" class="h-12 mx-auto" alt="Your initials">
            <% else %>
              <p class="text-center text-lg italic" style="font-family: Georgia, serif"><%= current_user.saved_initials %></p>
            <% end %>
          </div>
          <div class="mt-3 flex justify-between items-center">
            <span class="text-xs text-green-600 dark:text-green-400">Initials saved</span>
            <%= link_to "Clear", clear_initials_user_path(current_user),
                  data: { "turbo-method": "delete", turbo_confirm: "Clear your saved initials?" },
                  class: "text-xs text-red-500 hover:text-red-700 transition-colors" %>
          </div>
        <% else %>
          <div data-controller="signature-capture" data-signature-capture-type-value="initials">
            <div class="flex rounded-lg overflow-hidden border border-gray-300 dark:border-gray-600 mb-3">
              <button type="button" data-action="signature-capture#switchToDraw"
                      class="sig-cap-mode-btn flex-1 py-1.5 text-xs font-medium bg-blue-600 text-white transition-colors">Draw</button>
              <button type="button" data-action="signature-capture#switchToType"
                      class="sig-cap-mode-btn flex-1 py-1.5 text-xs font-medium bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 transition-colors">Type</button>
            </div>
            <div data-signature-capture-target="drawArea">
              <canvas data-signature-capture-target="canvas"
                      class="w-full border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg cursor-crosshair"
                      style="height: 120px; background-color: #ffffff; color-scheme: light;"></canvas>
            </div>
            <div data-signature-capture-target="typeArea" class="hidden">
              <input type="text" data-signature-capture-target="typeInput"
                     data-action="input->signature-capture#onTypeInput"
                     class="block w-full text-lg rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 py-2 px-3"
                     style="font-family: Georgia, cursive; font-size: 22px;"
                     placeholder="Type your initials">
            </div>
            <div class="mt-3 flex justify-between">
              <button type="button" data-action="signature-capture#clear"
                      class="text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">Clear</button>
              <button type="button" data-action="signature-capture#save"
                      data-signature-capture-target="saveBtn"
                      data-url="<%= update_initials_user_path(current_user) %>"
                      class="px-4 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">
                Save Initials
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Account Actions -->
  <div class="mt-6 bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">Account</h2>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-900 dark:text-gray-100">Password</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Send a password reset link to your email</p>
        </div>
        <%= button_to "Reset Password", new_user_password_path, method: :get, form: { class: "inline" },
            class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors cursor-pointer" %>
      </div>

      <% if current_user.organization&.stripe_customer_id.present? %>
        <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-gray-700">
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100">Subscription</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Current plan: <span class="font-semibold"><%= current_user.organization.plan_display_name %></span>
              <% if current_user.organization.subscription_status == "trialing" %>
                (trial)
              <% end %>
            </p>
          </div>
          <%= button_to "Manage Subscription", billing_portal_path, form: { data: { turbo: false } },
              class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
