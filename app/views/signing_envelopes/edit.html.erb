<% content_for :native_signals, native_form_tag %>
<% single_signer = @roles.count == 1 %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="pdf-signature-placement"
     data-pdf-signature-placement-pdf-url-value="<%= rails_blob_path(@document.file, disposition: 'inline') %>"
     data-pdf-signature-placement-multi-signer-value="<%= !single_signer %>"
     data-pdf-signature-placement-saved-signature-value="<%= current_user.saved_signature || '' %>"
     data-pdf-signature-placement-saved-initials-value="<%= current_user.saved_initials || '' %>"
     tabindex="0"
     data-action="keydown->pdf-signature-placement#handleKeyDown">

  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= single_signer ? "Place Signature Fields" : "Multi-Signer Setup" %></h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Document: <strong><%= @document.name %></strong></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if @envelope.draft? %>
        <%= link_to "Discard Draft", discard_draft_document_signing_envelope_path(@document, @envelope), data: { "turbo-method": "delete", turbo_confirm: "Discard this draft?" }, class: "px-3 py-1.5 text-sm text-red-600 border border-red-300 dark:border-red-500/50 rounded-md hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" %>
      <% end %>
      <%= link_to "Back to Document", document_path(@document), class: "px-3 py-1.5 text-sm text-gray-600 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- PDF Canvas -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-lg shadow-sm">
        <div class="px-6 py-3 border-b border-gray-200 flex items-center justify-center space-x-3">
          <button type="button" data-action="pdf-signature-placement#previousPage" aria-label="Previous page" class="p-1.5 text-gray-500 hover:text-gray-600 rounded-md hover:bg-gray-100 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <span data-pdf-signature-placement-target="pageIndicator" class="text-xs text-gray-500 tabular-nums">Page 1 of 1</span>
          <button type="button" data-action="pdf-signature-placement#nextPage" aria-label="Next page" class="p-1.5 text-gray-500 hover:text-gray-600 rounded-md hover:bg-gray-100 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div data-pdf-signature-placement-target="loadingState" class="flex items-center justify-center py-32">
          <div class="text-center">
            <svg class="animate-spin h-8 w-8 text-blue-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <p class="text-sm text-gray-500">Loading document...</p>
          </div>
        </div>

        <div data-pdf-signature-placement-target="canvasContainer" class="hidden p-4 overflow-hidden">
          <canvas data-pdf-signature-placement-target="canvas"
                  data-action="mousedown->pdf-signature-placement#handleCanvasMouseDown mousemove->pdf-signature-placement#handleCanvasHover"
                  class="mx-auto border border-gray-200 rounded-lg shadow-sm cursor-crosshair max-w-full">
          </canvas>
          <p class="text-center text-xs text-gray-500 mt-3">Click to place. Click a field to select, then <kbd class="px-1 py-0.5 bg-gray-100 border border-gray-300 rounded text-xs">Delete</kbd> to remove.</p>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="lg:col-span-1 space-y-5">
      <%= form_with url: document_signing_envelope_path(@document, @envelope), method: :patch, local: true do |f| %>
        <input type="hidden" name="fields_json" data-pdf-signature-placement-target="fieldsInput"
               value="<%= (@draft_request&.signature_fields || []).map { |sf| { page_number: sf.page_number, x_percent: sf.x_percent, y_percent: sf.y_percent, width_percent: sf.width_percent, height_percent: sf.height_percent, field_type: sf.field_type, required: sf.required, position: sf.position, label: sf.read_attribute(:label), role_id: sf.signing_role_id, role_color: sf.signing_role&.color } }.to_json %>">
        <input type="hidden" name="self_sign_data" data-pdf-signature-placement-target="selfSignDataInput" value="{}">

        <% if single_signer %>
          <%# === Single-signer mode: simplified signer card === %>
          <% role = @roles.first %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm" data-controller="contact-picker" data-contact-picker-url-value="<%= search_contacts_path %>">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Signer Details</h2>
            </div>
            <div class="px-6 py-4 space-y-4">
              <div class="relative">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
                <input type="email" name="roles[<%= role.id %>][signer_email]" value="<%= role.signer_email %>"
                       class="mt-1 block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 transition-colors"
                       placeholder="signer@example.com"
                       data-contact-picker-target="email" data-action="input->contact-picker#onEmailInput input->pdf-signature-placement#onRoleDetailChanged">
                <div data-contact-picker-target="suggestions" class="hidden absolute z-10 mt-1 w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md shadow-lg max-h-48 overflow-y-auto"></div>
                <div data-contact-picker-target="linkedBadge" class="hidden mt-1.5"></div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Name</label>
                <input type="text" name="roles[<%= role.id %>][signer_name]" value="<%= role.signer_name %>"
                       class="mt-1 block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 transition-colors"
                       placeholder="Full name"
                       data-contact-picker-target="name" data-action="input->pdf-signature-placement#onRoleDetailChanged">
              </div>
              <input type="hidden" name="roles[<%= role.id %>][label]" value="<%= role.label %>">
              <label class="flex items-center space-x-2 cursor-pointer">
                <input type="hidden" name="roles[<%= role.id %>][is_self_signer]" value="0">
                <input type="checkbox" name="roles[<%= role.id %>][is_self_signer]" value="1"
                       <%= "checked" if role.is_self_signer %>
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 transition-colors"
                       data-action="change->pdf-signature-placement#toggleSelfSigner"
                       data-role-id="<%= role.id %>">
                <span class="text-xs text-gray-600 dark:text-gray-400">I'm signing this myself</span>
              </label>
              <% if role.is_self_signer %>
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  <span class="font-medium"><%= current_user.full_name %></span> (<%= current_user.email %>)
                </p>
              <% end %>
            </div>
          </div>

          <%# Hidden role card target so Stimulus can find it %>
          <div class="hidden"
               data-role-id="<%= role.id %>"
               data-role-color="<%= role.color %>"
               data-pdf-signature-placement-target="roleCard"
               id="role-card-<%= role.id %>">
          </div>

          <%# Add Signer button %>
          <button type="submit" name="add_signer" value="1"
                  formaction="<%= add_role_document_signing_envelope_path(@document, @envelope) %>"
                  formmethod="post"
                  class="flex items-center justify-center w-full py-2 px-3 text-sm font-medium text-blue-600 dark:text-blue-400 border border-dashed border-blue-300 dark:border-blue-600 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors cursor-pointer">
            <svg class="h-4 w-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            + Add Another Signer
          </button>

        <% else %>
          <%# === Multi-signer mode: full roles panel === %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Signers</h2>
            </div>
            <div class="px-4 py-4 space-y-4">
              <% @roles.each_with_index do |role, index| %>
                <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-3 space-y-3 cursor-pointer transition-colors hover:border-gray-300 dark:hover:border-gray-600"
                     data-action="click->pdf-signature-placement#setActiveRole"
                     data-role-id="<%= role.id %>"
                     data-role-color="<%= role.color %>"
                     data-pdf-signature-placement-target="roleCard"
                     id="role-card-<%= role.id %>">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                      <span class="inline-block w-3 h-3 rounded-full shrink-0" style="background-color: <%= role.color %>"></span>
                      <input type="text" name="roles[<%= role.id %>][label]" value="<%= role.label %>"
                             class="text-sm font-medium text-gray-900 dark:text-gray-100 bg-transparent border-0 p-0 focus:ring-0 w-28"
                             placeholder="Signer name"
                             data-action="input->pdf-signature-placement#onRoleDetailChanged">
                    </div>
                    <div class="flex items-center space-x-1">
                      <button type="button"
                              data-action="click->pdf-signature-placement#toggleRoleVisibility"
                              data-role-id="<%= role.id %>"
                              data-pdf-signature-placement-target="visibilityToggle"
                              class="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
                              title="Toggle field visibility">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      </button>
                      <% if @roles.count > 1 %>
                        <%= link_to remove_role_document_signing_envelope_path(@document, @envelope, role_id: role.id),
                              data: { "turbo-method": "delete", turbo_confirm: "Remove this signer?" },
                              class: "text-xs text-red-500 hover:text-red-700 transition-colors" do %>
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        <% end %>
                      <% end %>
                    </div>
                  </div>

                  <div class="space-y-2">
                    <label class="flex items-center space-x-2 cursor-pointer">
                      <input type="hidden" name="roles[<%= role.id %>][is_self_signer]" value="0">
                      <input type="checkbox" name="roles[<%= role.id %>][is_self_signer]" value="1"
                             <%= "checked" if role.is_self_signer %>
                             class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 transition-colors"
                             data-action="change->pdf-signature-placement#toggleSelfSigner"
                             data-role-id="<%= role.id %>">
                      <span class="text-xs text-gray-600 dark:text-gray-400">I'm signing this role</span>
                    </label>

                    <div id="role-signer-fields-<%= role.id %>" class="<%= 'hidden' if role.is_self_signer %> space-y-2">
                      <input type="email" name="roles[<%= role.id %>][signer_email]" value="<%= role.signer_email %>"
                             class="block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 transition-colors"
                             placeholder="signer@example.com"
                             data-action="input->pdf-signature-placement#onRoleDetailChanged">
                      <input type="text" name="roles[<%= role.id %>][signer_name]" value="<%= role.signer_name %>"
                             class="block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 transition-colors"
                             placeholder="Full name"
                             data-action="input->pdf-signature-placement#onRoleDetailChanged">
                    </div>

                    <% if role.is_self_signer %>
                      <p class="text-xs text-gray-500 dark:text-gray-400">
                        <span class="font-medium"><%= current_user.full_name %></span> (<%= current_user.email %>)
                      </p>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <button type="submit" name="add_signer" value="1"
                      formaction="<%= add_role_document_signing_envelope_path(@document, @envelope) %>"
                      formmethod="post"
                      class="flex items-center justify-center w-full py-2 px-3 text-sm font-medium text-blue-600 dark:text-blue-400 border border-dashed border-blue-300 dark:border-blue-600 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors cursor-pointer">
                <svg class="h-4 w-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Add Signer
              </button>
            </div>

            <!-- Signing Mode Toggle -->
            <div class="px-4 pb-4">
              <div class="flex rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                <label class="flex-1 text-center cursor-pointer">
                  <input type="radio" name="signing_mode" value="parallel" <%= "checked" if @envelope.parallel? %> class="hidden peer">
                  <span class="block py-2 text-xs font-medium peer-checked:bg-blue-600 peer-checked:text-white text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">All at once</span>
                </label>
                <label class="flex-1 text-center cursor-pointer border-l border-gray-200 dark:border-gray-700">
                  <input type="radio" name="signing_mode" value="sequential" <%= "checked" if @envelope.sequential? %> class="hidden peer">
                  <span class="block py-2 text-xs font-medium peer-checked:bg-blue-600 peer-checked:text-white text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">Sign in order</span>
                </label>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Templates -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Templates</h2>
          </div>
          <div class="px-6 py-4 space-y-2">
            <% templates = @document.signature_templates.by_recent %>
            <% if templates.any? %>
              <div class="space-y-1">
                <% templates.each do |template| %>
                  <div class="flex items-center justify-between py-1.5">
                    <span class="text-sm text-gray-700 dark:text-gray-300 truncate"><%= template.name %></span>
                    <div class="flex items-center space-x-2 shrink-0">
                      <%= link_to "Apply", apply_document_signature_template_path(@document, template),
                            data: { "turbo-method": "post" },
                            class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium transition-colors" %>
                      <%= link_to "Delete", document_signature_template_path(@document, template),
                            data: { "turbo-method": "delete", turbo_confirm: "Delete this template?" },
                            class: "text-xs text-red-500 hover:text-red-700 transition-colors" %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-xs text-gray-500 dark:text-gray-400 py-2 text-center">No templates saved yet</p>
            <% end %>
          </div>
          <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
            <details class="group">
              <summary class="text-xs font-medium text-blue-600 dark:text-blue-400 cursor-pointer hover:text-blue-800 dark:hover:text-blue-300 transition-colors flex items-center">
                <svg class="h-3 w-3 mr-1 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
                Save Current Fields as Template
              </summary>
              <div class="mt-2 space-y-2">
                <input type="text" data-pdf-signature-placement-target="templateNameInput" placeholder="Template name..." class="block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200">
                <button type="button"
                        data-action="pdf-signature-placement#saveTemplate"
                        data-template-url="<%= document_signature_templates_path(@document) %>"
                        class="w-full px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer">
                  Save Template
                </button>
              </div>
            </details>
          </div>
        </div>

        <!-- Field Type Picker -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
          <select data-pdf-signature-placement-target="addFieldType" class="hidden">
            <option value="signature">Signature</option>
            <option value="initials">Initials</option>
            <option value="name">Printed Name</option>
            <option value="date">Date Signed</option>
            <option value="text">Text</option>
            <option value="email">Email</option>
            <option value="company">Company</option>
            <option value="title">Title/Role</option>
            <option value="checkbox">Checkbox</option>
          </select>

          <div data-pdf-signature-placement-target="typePicker">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Select a type, then click on the document to place it.</p>
              <div class="flex flex-wrap gap-2">
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="signature" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-purple-100 text-purple-800 border-purple-300">Signature</button>
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="initials" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">Initials</button>
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="name" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">Name</button>
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="date" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">Date</button>
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="text" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">Text</button>
                <button type="button" data-action="pdf-signature-placement#selectFieldType" data-field-type="checkbox" data-pdf-signature-placement-target="fieldTypePill" class="px-3 py-1.5 text-xs font-medium rounded-full border transition-colors cursor-pointer bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">Checkbox</button>
              </div>
            </div>
          </div>

          <div data-pdf-signature-placement-target="fieldInspector" class="hidden"></div>

          <div class="px-6 py-3 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
            <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Fields</h2>
            <span data-pdf-signature-placement-target="fieldCount" class="text-xs text-gray-500 dark:text-gray-400">0 fields</span>
          </div>
          <div class="px-4 py-3 space-y-2" data-pdf-signature-placement-target="fieldsList">
            <p class="text-sm text-gray-500 dark:text-gray-400 py-4 text-center">Click on the document to place fields</p>
          </div>
        </div>

        <!-- Message -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
          <div class="px-6 py-4">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message (optional)</label>
            <textarea name="message" rows="2" class="block w-full text-sm rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 transition-colors" placeholder="Please sign this document..."><%= @envelope.message %></textarea>
          </div>
        </div>

        <!-- Actions -->
        <div class="space-y-3">
          <p data-pdf-signature-placement-target="selfSignWarning" class="hidden text-xs text-amber-600 dark:text-amber-400 text-center"></p>
          <button type="submit" name="send_envelope" value="1"
                  data-pdf-signature-placement-target="sendButton"
                  class="w-full px-4 py-3 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors cursor-pointer shadow-sm"
                  data-turbo-submits-with="Sending...">
            <% if single_signer %>
              Send for Signature
            <% else %>
              Send to <%= @roles.where(is_self_signer: false).count %> Signer<%= @roles.where(is_self_signer: false).count != 1 ? 's' : '' %>
            <% end %>
          </button>
          <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors cursor-pointer" data-turbo-submits-with="Saving...">
            Save Draft
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
