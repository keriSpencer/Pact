<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Tags</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage tags for organizing contacts</p>
  </div>

  <!-- Create Tag -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm mb-8">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">New Tag</h2>
    </div>
    <%= form_with(model: @tag, url: tags_path, method: :post, class: "px-6 py-5") do |form| %>
      <% if @tag.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-md p-4 mb-4" role="alert" aria-live="polite">
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-300">
            <% @tag.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex items-end space-x-4">
        <div class="flex-1">
          <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :name, class: "mt-1 block w-full", placeholder: "Tag name" %>
        </div>
        <div class="w-40">
          <%= form.label :color, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.select :color, Tag::COLORS.map { |c| [c.capitalize, c] }, {}, class: "mt-1 block w-full" %>
        </div>
        <%= form.submit "Create", class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer", data: { turbo_submits_with: "Creating..." } %>
      </div>
    <% end %>
  </div>

  <!-- Existing Tags -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">All Tags (<%= @tags.count %>)</h2>
    </div>
    <% if @tags.any? %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @tags.each do |tag| %>
          <li class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
            <div class="flex items-center">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= tag.bg_class %> <%= tag.text_class %>">
                <%= tag.name %>
              </span>
              <% if tag.description.present? %>
                <span class="ml-3 text-sm text-gray-500 dark:text-gray-400"><%= tag.description %></span>
              <% end %>
              <span class="ml-3 text-xs text-gray-500 dark:text-gray-400"><%= tag.contacts.count %> contacts</span>
            </div>
            <%= link_to "Delete", tag_path(tag), data: { "turbo-method": "delete", turbo_confirm: "Delete tag '#{tag.name}'?" }, class: "text-sm text-red-600 hover:text-red-800 transition-colors" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No tags yet</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Create your first tag above to start organizing contacts.</p>
      </div>
    <% end %>
  </div>
</div>
