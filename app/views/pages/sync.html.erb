<% content_for(:title, "PactSync for Mac — Desktop File Syncing | Pact") %>

<!-- Hero -->
<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-white via-white to-blue-50/80"></div>
  <div class="absolute inset-0 opacity-40" style="background-image: radial-gradient(circle at 1px 1px, rgb(209 213 219) 1px, transparent 0); background-size: 32px 32px;"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 lg:pt-28 lg:pb-20">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm font-medium text-blue-700 mb-6">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        macOS App
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight">
        PactSync <span class="text-blue-600">for Mac</span>
      </h1>
      <p class="mt-6 text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Automatically sync folders on your Mac with your Pact account. Drop files in a folder, they show up in Pact. Upload to Pact, they appear on your Mac.
      </p>
      <div class="mt-8">
        <a href="#download" class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-600/25 transition-all hover:shadow-xl hover:shadow-blue-600/30">
          Download PactSync
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>
      </div>
      <p class="mt-3 text-sm text-gray-400">Requires macOS 14 (Sonoma) or later</p>
    </div>
  </div>
</section>

<!-- Features Grid -->
<section class="py-16 lg:py-24 border-t border-gray-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-10">
      <div class="text-center">
        <div class="mx-auto h-12 w-12 rounded-2xl bg-blue-50 flex items-center justify-center">
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Two-Way Sync</h3>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">Files sync in both directions. Add a file locally or via the web &mdash; it appears everywhere.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto h-12 w-12 rounded-2xl bg-blue-50 flex items-center justify-center">
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Lightweight</h3>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">Native Swift app that lives in your menu bar. No Electron, no bloat, minimal resource usage.</p>
      </div>
      <div class="text-center">
        <div class="mx-auto h-12 w-12 rounded-2xl bg-blue-50 flex items-center justify-center">
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-gray-900">Secure</h3>
        <p class="mt-2 text-sm text-gray-500 leading-relaxed">Uses your existing Pact credentials. Files are transferred over HTTPS and stored encrypted.</p>
      </div>
    </div>
  </div>
</section>

