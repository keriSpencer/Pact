<h2>You have a document to sign</h2>

<p>Hello <%= @signature_request.signer_display_name %>,</p>

<p>
  <strong><%= @signature_request.requester.full_name %></strong> has sent you a document to review and sign.
</p>

<div class="highlight">
  <p><strong>Document:</strong> <%= @document.name %></p>
  <p><strong>From:</strong> <%= @signature_request.requester.full_name %></p>
  <% if @signature_request.expires_at.present? %>
    <p><strong>Expires:</strong> <%= @signature_request.expires_at.strftime("%B %d, %Y") %></p>
  <% end %>
</div>

<% if @signature_request.message.present? %>
  <div class="message-block">
    <p>"<%= @signature_request.message %>"</p>
  </div>
<% end %>

<p style="text-align: center; margin: 24px 0;">
  <a href="<%= @signing_url %>" class="btn-primary">
    Review and Sign
  </a>
</p>

<p class="link-fallback">
  If the button above doesn't work, copy and paste this link into your browser:<br>
  <%= @signing_url %>
</p>
