<% content_for(:title) { "Signed Successfully - Pact" } %>

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
  <div class="bg-white rounded-xl shadow-sm p-8 sm:p-12">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
      <svg class="h-10 w-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-gray-900">Document Signed Successfully</h1>

    <p class="mt-3 text-gray-600">
      You have successfully signed
      "<strong><%= @signature_request.document.name %></strong>".
    </p>

    <div class="mt-6 bg-gray-50 rounded-lg p-4 text-left space-y-2">
      <div class="flex justify-between">
        <span class="text-sm text-gray-500">Signed by</span>
        <span class="text-sm font-medium text-gray-900"><%= @signature_request.signer_display_name %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-gray-500">Date</span>
        <span class="text-sm font-medium text-gray-900"><%= @signature_request.signed_at&.strftime("%B %d, %Y at %l:%M %p") %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-gray-500">Requested by</span>
        <span class="text-sm font-medium text-gray-900"><%= @signature_request.requester.full_name %></span>
      </div>
    </div>

    <% signed_version = @signature_request.signed_version %>
    <% if signed_version&.file&.attached? %>
      <div class="mt-6 flex justify-center space-x-4">
        <%= link_to rails_blob_path(signed_version.file, disposition: "inline"), target: "_blank", class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          View Signed PDF
        <% end %>
        <%= link_to rails_blob_path(signed_version.file, disposition: "attachment"), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download
        <% end %>
      </div>
    <% end %>

    <p class="mt-6 text-sm text-gray-500">
      A confirmation email has been sent to you and
      <strong><%= @signature_request.requester.full_name %></strong>.
    </p>
    <p class="mt-2 text-xs text-gray-400">Bookmark this page to return to your signed copy anytime.</p>
  </div>
</div>
