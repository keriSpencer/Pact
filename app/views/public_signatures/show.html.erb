<% content_for(:title) { "Sign Document - Pact" } %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
  <% if @signature_request.signed? %>
    <!-- Already signed - redirect should have happened, but show fallback -->
    <div class="bg-white rounded-xl shadow-sm p-8 sm:p-12 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 mb-4">
        <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900">Document Signed</h2>
      <p class="mt-2 text-gray-600">
        You signed "<strong><%= @signature_request.document.name %></strong>"
        on <%= @signature_request.signed_at&.strftime("%B %d, %Y at %l:%M %p") %>.
      </p>
      <p class="mt-4 text-sm text-gray-500">You may close this window.</p>
    </div>

  <% elsif @signature_request.declined? %>
    <div class="bg-white rounded-xl shadow-sm p-8 sm:p-12 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
        <svg class="h-8 w-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900">Signature Declined</h2>
      <p class="mt-2 text-gray-600">You declined to sign "<strong><%= @signature_request.document.name %></strong>".</p>
    </div>

  <% elsif @signature_request.cancelled? || @signature_request.voided? || @signature_request.expired? %>
    <div class="bg-white rounded-xl shadow-sm p-8 sm:p-12 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-yellow-100 mb-4">
        <svg class="h-8 w-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900">Request <%= @signature_request.status.humanize %></h2>
      <p class="mt-2 text-gray-600">This signature request is no longer active.</p>
      <p class="mt-4 text-sm text-gray-500">
        If you believe this is an error, please contact the person who sent you this request
        (<strong><%= @signature_request.requester.full_name %></strong>) to resend or create a new signing request.
      </p>
    </div>

  <% elsif @signature_request.can_sign? %>
    <%
      completed_count = @fields.select(&:completed?).count
      required_count = @fields.select(&:required?).count
      total_count = @fields.count
    %>

    <!-- Document Info Header -->
    <div class="bg-white rounded-xl shadow-sm mb-5">
      <div class="px-6 py-5">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="text-lg font-semibold text-gray-900"><%= @signature_request.document.name %></h2>
            <p class="text-sm text-gray-500 mt-1">
              From <strong><%= @signature_request.requester.full_name %></strong>
            </p>
          </div>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            Action Required
          </span>
        </div>
        <% if @signature_request.message.present? %>
          <div class="mt-3 bg-gray-50 rounded-lg p-3">
            <p class="text-sm text-gray-600 italic">"<%= @signature_request.message %>"</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Document Preview -->
    <% if @signature_request.document.pdf? && @signature_request.document.file.attached? %>
      <div class="bg-white rounded-xl shadow-sm mb-5">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-sm font-medium text-gray-700">Document Preview</h3>
        </div>
        <div class="p-4">
          <iframe src="<%= rails_blob_path(@signature_request.document.file, disposition: 'inline') %>"
                  class="w-full h-64 sm:h-80 border border-gray-200 rounded-lg"
                  title="Document preview"></iframe>
        </div>
      </div>
    <% end %>

    <% if @signature_request.uses_multi_field? %>
      <!-- Multi-field Signing -->
      <div class="bg-white rounded-xl shadow-sm mb-5">
        <div class="px-6 py-4 border-b border-gray-200">
          <div class="flex justify-between items-center">
            <h3 class="text-sm font-semibold text-gray-900">Complete Fields</h3>
            <span class="text-sm text-gray-500"><%= completed_count %> of <%= total_count %> completed</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-3">
            <div class="bg-blue-600 h-2 rounded-full transition-all duration-300"
                 style="width: <%= total_count > 0 ? ((completed_count.to_f / total_count) * 100).round : 0 %>%"></div>
          </div>
        </div>

        <div class="divide-y divide-gray-100">
          <% @fields.each_with_index do |field, index| %>
            <div class="px-6 py-4 <%= field.completed? ? 'bg-green-50' : '' %>">
              <div class="flex items-start justify-between mb-2">
                <div class="flex items-center space-x-2">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-medium
                    <%= field.completed? ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-600' %>">
                    <% if field.completed? %>
                      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    <% else %>
                      <%= index + 1 %>
                    <% end %>
                  </span>
                  <div>
                    <span class="text-sm font-medium text-gray-900"><%= field.label %></span>
                    <% if field.required? %><span class="text-red-500 ml-0.5">*</span><% end %>
                    <span class="text-xs text-gray-500 block">Page <%= field.page_number %> &middot; <%= field.field_type.humanize %></span>
                  </div>
                </div>
                <% if field.completed? %>
                  <span class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full font-medium"
                        title="<%= field.completion&.completed_at&.strftime('%B %d, %Y at %l:%M:%S %p') %>">
                    Completed
                  </span>
                <% end %>
              </div>

              <% if field.completed? %>
                <div class="ml-8 flex items-center justify-between">
                  <p class="text-xs text-gray-500" title="<%= field.completion&.completed_at&.strftime('%B %d, %Y at %l:%M:%S %p %Z') %>">
                    Completed <%= field.completion&.completed_at&.strftime("%b %d at %l:%M %p") %>
                  </p>
                  <%= form_with url: reset_field_signature_path(@signature_request.signature_token), method: :post, class: "inline" do %>
                    <input type="hidden" name="field_id" value="<%= field.id %>">
                    <button type="submit" class="text-xs text-gray-500 hover:text-gray-600 underline transition-colors">Reset</button>
                  <% end %>
                </div>
              <% else %>
                <div class="ml-8 mt-2">
                  <% if %w[signature initials].include?(field.field_type) %>
                    <!-- Signature/Initials with draw or type -->
                    <div data-controller="signature-pad">
                      <div data-signature-pad-target="modeToggle" class="flex rounded-md border border-gray-200 overflow-hidden mb-3 w-fit">
                        <button type="button" data-mode="draw" data-action="click->signature-pad#switchToDraw"
                                class="px-3 py-1.5 text-xs font-medium bg-blue-600 text-white transition-colors cursor-pointer">Draw</button>
                        <button type="button" data-mode="type" data-action="click->signature-pad#switchToType"
                                class="px-3 py-1.5 text-xs font-medium bg-white text-gray-700 transition-colors cursor-pointer">Type</button>
                      </div>

                      <%= form_with url: capture_artifact_signature_path(@signature_request.signature_token), method: :post do %>
                        <input type="hidden" name="artifact_type" value="<%= field.field_type %>">
                        <input type="hidden" name="field_id" value="<%= field.id %>">
                        <input type="hidden" name="capture_method" value="drawn" data-signature-pad-target="input" id="sig_data_<%= field.id %>">

                        <!-- Draw mode -->
                        <div data-signature-pad-target="drawMode">
                          <canvas data-signature-pad-target="canvas"
                                  class="border-2 border-dashed border-gray-300 rounded-lg bg-white cursor-crosshair w-full touch-none"
                                  style="height: min(200px, 30vh);"></canvas>
                          <div class="flex justify-end mt-1">
                            <button type="button" data-action="click->signature-pad#clear"
                                    class="text-xs text-gray-500 hover:text-gray-700 transition-colors cursor-pointer">Clear</button>
                          </div>
                        </div>

                        <!-- Type mode -->
                        <div data-signature-pad-target="typeMode" class="hidden">
                          <input type="text" data-signature-pad-target="typedInput"
                                 data-action="input->signature-pad#updateFromTyped"
                                 name="typed_text"
                                 class="block w-full rounded-lg border-gray-300 text-xl py-3 px-4"
                                 style="font-family: 'Brush Script MT', 'Segoe Script', cursive;"
                                 placeholder="Type your <%= field.field_type %>...">
                        </div>

                        <button type="submit" class="mt-3 w-full sm:w-auto px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer" data-turbo-submits-with="Applying...">
                          Apply <%= field.field_type.humanize %>
                        </button>
                      <% end %>
                    </div>

                  <% elsif field.field_type == "date" %>
                    <!-- Date field -->
                    <%= form_with url: capture_artifact_signature_path(@signature_request.signature_token), method: :post, class: "flex items-end space-x-3" do %>
                      <input type="hidden" name="artifact_type" value="date">
                      <input type="hidden" name="capture_method" value="typed">
                      <input type="hidden" name="field_id" value="<%= field.id %>">
                      <div class="flex-1">
                        <input type="text" name="artifact_data"
                               value="<%= Time.current.strftime('%B %d, %Y at %l:%M %p') %>"
                               class="block w-full rounded-lg border-gray-300 text-sm"
                               readonly>
                      </div>
                      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 shrink-0 transition-colors cursor-pointer" data-turbo-submits-with="Applying...">
                        Apply Date
                      </button>
                    <% end %>

                  <% else %>
                    <!-- Text/name/email/etc. -->
                    <%= form_with url: capture_artifact_signature_path(@signature_request.signature_token), method: :post, class: "flex items-end space-x-3" do %>
                      <input type="hidden" name="artifact_type" value="<%= field.field_type %>">
                      <input type="hidden" name="capture_method" value="typed">
                      <input type="hidden" name="field_id" value="<%= field.id %>">
                      <div class="flex-1">
                        <input type="text" name="artifact_data" required
                               class="block w-full rounded-lg border-gray-300 text-sm"
                               placeholder="Enter <%= field.field_type.humanize.downcase %>...">
                      </div>
                      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 shrink-0 transition-colors cursor-pointer" data-turbo-submits-with="Saving...">
                        Save
                      </button>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Submit button -->
      <div class="bg-white rounded-xl shadow-sm p-6 mb-5">
        <%= form_with url: finalize_signature_path(@signature_request.signature_token), method: :post do %>
          <button type="submit"
                  class="w-full px-6 py-4 text-base font-semibold text-white bg-green-600 rounded-xl hover:bg-green-700 transition-colors cursor-pointer
                    <%= @signature_request.all_required_fields_completed? ? '' : 'opacity-50 cursor-not-allowed' %>"
                  <%= @signature_request.all_required_fields_completed? ? '' : 'disabled' %>
                  aria-disabled="<%= !@signature_request.all_required_fields_completed? %>"
                  title="<%= @signature_request.all_required_fields_completed? ? 'Submit your signed document' : 'Please complete all required fields before submitting' %>"
                  data-turbo-submits-with="Submitting...">
            Submit Signed Document
          </button>
          <p class="text-xs text-gray-500 text-center mt-3">
            By submitting, you agree that this electronic signature is the legal equivalent of your manual/handwritten signature.
          </p>
        <% end %>
      </div>

    <% else %>
      <!-- Single-field (legacy) signing -->
      <div class="bg-white rounded-xl shadow-sm mb-5" data-controller="signature-pad">
        <div class="px-6 py-4 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900">Sign Document</h3>
        </div>
        <div class="px-6 py-5">
          <%= form_with url: sign_signature_path(@signature_request.signature_token), method: :post, class: "space-y-4" do %>
            <div data-signature-pad-target="modeToggle" class="flex rounded-md border border-gray-200 overflow-hidden mb-3 w-fit">
              <button type="button" data-mode="draw" data-action="click->signature-pad#switchToDraw"
                      class="px-3 py-1.5 text-xs font-medium bg-blue-600 text-white transition-colors cursor-pointer">Draw</button>
              <button type="button" data-mode="type" data-action="click->signature-pad#switchToType"
                      class="px-3 py-1.5 text-xs font-medium bg-white text-gray-700 transition-colors cursor-pointer">Type</button>
            </div>

            <input type="hidden" name="signature_data" data-signature-pad-target="input">

            <!-- Draw mode -->
            <div data-signature-pad-target="drawMode">
              <canvas data-signature-pad-target="canvas"
                      class="border-2 border-dashed border-gray-300 rounded-lg bg-white cursor-crosshair w-full touch-none"
                      style="height: min(200px, 30vh);"></canvas>
              <div class="flex justify-end mt-1">
                <button type="button" data-action="click->signature-pad#clear"
                        class="text-xs text-gray-500 hover:text-gray-700 transition-colors cursor-pointer">Clear</button>
              </div>
            </div>

            <!-- Type mode -->
            <div data-signature-pad-target="typeMode" class="hidden">
              <input type="text" data-signature-pad-target="typedInput"
                     data-action="input->signature-pad#updateFromTyped"
                     class="block w-full rounded-lg border-gray-300 text-xl py-3 px-4"
                     style="font-family: 'Brush Script MT', 'Segoe Script', cursive;"
                     placeholder="Type your full name...">
            </div>

            <p class="text-xs text-gray-500">By signing, you agree that this electronic signature is the legal equivalent of your manual/handwritten signature.</p>
            <button type="submit" class="w-full px-4 py-3 text-sm font-semibold text-white bg-green-600 rounded-xl hover:bg-green-700 transition-colors cursor-pointer" data-turbo-submits-with="Signing...">
              Sign Document
            </button>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Report an Issue / Decline -->
    <div class="bg-white rounded-xl shadow-sm p-6">
      <details class="group">
        <summary class="text-sm font-medium text-gray-500 cursor-pointer hover:text-gray-700 transition-colors list-none flex items-center">
          <svg class="h-4 w-4 mr-2 text-gray-400 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          Report an Issue or Decline to Sign
        </summary>
        <div class="mt-4">
          <%= form_with url: decline_signature_path(@signature_request.signature_token), method: :post, class: "space-y-3" do %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Reason (optional)</label>
              <textarea name="decline_reason" rows="2" class="block w-full rounded-lg border-gray-300 text-sm" placeholder="Explain why you're declining..."></textarea>
            </div>
            <button type="submit" class="px-4 py-2 text-sm font-medium text-red-600 bg-white border border-red-300 rounded-md hover:bg-red-50 transition-colors cursor-pointer"
                    data-turbo-confirm="Are you sure you want to decline signing this document?"
                    data-turbo-submits-with="Declining...">
              Decline to Sign
            </button>
          <% end %>
        </div>
      </details>
    </div>
  <% end %>
</div>
