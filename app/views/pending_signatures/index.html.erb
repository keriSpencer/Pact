<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center gap-2 mb-1">
      <%= link_to dashboard_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" do %>
        <svg class="inline h-4 w-4 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Dashboard
      <% end %>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @page_title %></h1>
  </div>

  <!-- Filter Tabs -->
  <div class="flex gap-1 mb-6 bg-gray-100 dark:bg-gray-800 rounded-lg p-1 w-fit">
    <%= link_to pending_signatures_path, class: "px-4 py-2 text-sm font-medium rounded-md transition-colors #{!@signed_filter ? 'bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm' : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200'}" do %>
      Pending
      <% if @pending_count > 0 %>
        <span class="ml-1.5 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-medium rounded-full <%= !@signed_filter ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300' : 'bg-gray-200 text-gray-600 dark:bg-gray-600 dark:text-gray-300' %>"><%= @pending_count %></span>
      <% end %>
    <% end %>
    <%= link_to pending_signatures_path(filter: "signed"), class: "px-4 py-2 text-sm font-medium rounded-md transition-colors #{@signed_filter ? 'bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm' : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200'}" do %>
      Signed
      <% if @signed_count > 0 %>
        <span class="ml-1.5 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-medium rounded-full <%= @signed_filter ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-200 text-gray-600 dark:bg-gray-600 dark:text-gray-300' %>"><%= @signed_count %></span>
      <% end %>
    <% end %>
  </div>

  <!-- Request List -->
  <% if @requests.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm divide-y divide-gray-200 dark:divide-gray-700">
      <% @requests.each do |sr| %>
        <div class="px-5 py-4 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <!-- Left: Document + Signer info -->
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-3 mb-1">
                <%= link_to sr.document.name, document_path(sr.document), class: "text-sm font-semibold text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 truncate transition-colors" %>
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <span class="truncate">
                  <%= sr.signer_email %>
                  <% if sr.signer_name.present? %>
                    <span class="text-gray-400 dark:text-gray-500">(<%= sr.signer_name %>)</span>
                  <% end %>
                </span>
              </div>
              <% if sr.signing_envelope.present? %>
                <% envelope = sr.signing_envelope %>
                <% total_roles = envelope.signing_roles.count %>
                <% signed_roles = envelope.signing_roles.joins(:signature_request).where(signature_requests: { status: :signed }).count %>
                <div class="flex items-center gap-2 mt-1.5 text-xs text-gray-400 dark:text-gray-500">
                  <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <span>Multi-signer &middot; <%= signed_roles %> of <%= total_roles %> signed</span>
                </div>
              <% end %>
            </div>

            <!-- Right: Status + Time + Actions -->
            <div class="flex flex-col items-end gap-2 shrink-0">
              <div class="flex items-center gap-2">
                <% if @signed_filter %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300">Signed</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= sr.status_color_class %> dark:bg-opacity-40"><%= sr.status.humanize %></span>
                <% end %>
              </div>
              <span class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap">
                <% if @signed_filter && sr.signed_at %>
                  Signed <%= time_ago_in_words(sr.signed_at) %> ago
                <% elsif sr.sent_at %>
                  Sent <%= time_ago_in_words(sr.sent_at) %> ago
                <% else %>
                  Created <%= time_ago_in_words(sr.created_at) %> ago
                <% end %>
              </span>
              <% unless @signed_filter %>
                <div class="flex items-center gap-2">
                  <%= button_to resend_document_signature_request_path(sr.document, sr), method: :post, class: "text-xs font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors", data: { turbo_confirm: "Resend signature request to #{sr.signer_display_name}?" } do %>
                    Resend
                  <% end %>
                  <%= button_to void_document_signature_request_path(sr.document, sr), method: :post, class: "text-xs font-medium text-gray-400 dark:text-gray-500 hover:text-red-600 dark:hover:text-red-400 transition-colors", data: { turbo_confirm: "Void this signature request? This cannot be undone." } do %>
                    Void
                  <% end %>
                </div>
              <% else %>
                <% if sr.document.pdf? %>
                  <%= link_to download_document_path(sr.document), class: "text-xs font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors" do %>
                    View PDF
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm px-6 py-16 text-center">
      <% if @signed_filter %>
        <svg class="mx-auto h-10 w-10 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">No signed documents yet</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Completed signatures will appear here.</p>
      <% else %>
        <svg class="mx-auto h-10 w-10 text-green-400 dark:text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-gray-100">All clear</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">No pending signature requests right now.</p>
      <% end %>
    </div>
  <% end %>
</div>
