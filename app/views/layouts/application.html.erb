<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Pact" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Pact - Contacts and document signing made simple">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#2563EB">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :ruby_native, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen">
    <% if user_signed_in? %>
      <%= native_tabs_tag %>
      <%= yield :native_signals %>
      <!-- Navigation -->
      <nav class="bg-white dark:bg-gray-800 shadow dark:shadow-gray-900/50 fixed top-0 left-0 right-0 z-50" role="navigation" aria-label="Main navigation">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center">
              <%= native_back_button_tag "Back", class: "text-sm text-blue-600 dark:text-blue-400 mr-2" %>
              <div class="flex-shrink-0 flex items-center">
                <%= link_to dashboard_path, class: "flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-gray-100", "aria-label": "Pact Home" do %>
                  <svg class="h-7 w-7" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M 100 35 L 55 55 Q 50 57 50 63 L 50 95 Q 50 130 100 165 Q 150 130 150 95 L 150 63 Q 150 57 145 55 Z" stroke="#2563EB" stroke-width="8" stroke-linejoin="round"/>
                    <path d="M 72 105 L 92 125 L 132 80" stroke="#2563EB" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Pact
                <% end %>
              </div>
              <!-- Desktop nav links -->
              <div class="hidden sm:ml-6 sm:flex sm:space-x-6" role="menubar">
                <%= link_to dashboard_path, class: "#{request.path == dashboard_path ? 'text-blue-600 dark:text-blue-400 font-semibold' : 'text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100'} inline-flex items-center px-1 text-sm font-medium transition-colors", role: "menuitem" do %>
                  Dashboard
                <% end %>
                <%= link_to contacts_path, class: "#{request.path.start_with?('/contacts') ? 'text-blue-600 dark:text-blue-400 font-semibold' : 'text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100'} inline-flex items-center px-1 text-sm font-medium transition-colors", role: "menuitem" do %>
                  Contacts
                <% end %>
                <%= link_to folders_path, class: "#{request.path.start_with?('/folders') || request.path.start_with?('/documents') ? 'text-blue-600 dark:text-blue-400 font-semibold' : 'text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100'} inline-flex items-center px-1 text-sm font-medium transition-colors", role: "menuitem" do %>
                  Documents
                <% end %>
                <%= link_to billing_path, class: "#{request.path == billing_path ? 'text-blue-600 dark:text-blue-400 font-semibold' : 'text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100'} inline-flex items-center px-1 text-sm font-medium transition-colors", role: "menuitem" do %>
                  Billing
                <% end %>
              </div>
            </div>
            <!-- Right side -->
            <div class="hidden sm:flex sm:items-center sm:space-x-4">
              <div class="relative">
                <%= form_with url: search_path, method: :get, local: true, class: "relative" do |form| %>
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-4 w-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                  </div>
                  <%= form.text_field :q, value: params[:q], placeholder: "Search...", autocomplete: "off",
                      class: "block w-48 pl-9 pr-3 py-1.5 border border-gray-200 dark:border-gray-600 rounded-lg text-sm bg-gray-50 dark:bg-gray-700 dark:text-gray-200 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:bg-white dark:focus:bg-gray-600 focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-all" %>
                <% end %>
              </div>
              <div class="flex items-center">
                <%= link_to user_path(current_user), class: "flex items-center text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100" do %>
                  <div class="h-7 w-7 rounded-full bg-blue-600 flex items-center justify-center">
                    <span class="text-xs font-medium text-white"><%= current_user.initials %></span>
                  </div>
                <% end %>
                <%= link_to "Sign out", destroy_user_session_path, data: { "turbo-method": "delete" }, class: "ml-3 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" %>
              </div>
            </div>
            <!-- Mobile right side -->
            <div class="flex items-center sm:hidden">
              <%= link_to user_path(current_user), class: "p-2", "aria-label": "Profile" do %>
                <div class="h-7 w-7 rounded-full bg-blue-600 flex items-center justify-center">
                  <span class="text-xs font-medium text-white"><%= current_user.initials %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <% unless native_app? %>
        <!-- Mobile Bottom Tab Bar -->
        <nav class="sm:hidden fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 safe-area-inset-bottom" role="navigation" aria-label="Mobile navigation">
          <div class="flex justify-around items-center h-14">
            <%= link_to dashboard_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{request.path == dashboard_path ? 'text-blue-600 dark:text-blue-400' : 'text-gray-500 dark:text-gray-400'}" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span class="text-xs mt-0.5">Home</span>
            <% end %>
            <%= link_to contacts_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{request.path.start_with?('/contacts') ? 'text-blue-600 dark:text-blue-400' : 'text-gray-500 dark:text-gray-400'}" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
              <span class="text-xs mt-0.5">Contacts</span>
            <% end %>
            <%= link_to folders_path, class: "flex flex-col items-center justify-center flex-1 py-2 #{request.path.start_with?('/folders') || request.path.start_with?('/documents') ? 'text-blue-600 dark:text-blue-400' : 'text-gray-500 dark:text-gray-400'}" do %>
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              <span class="text-xs mt-0.5">Docs</span>
            <% end %>
          </div>
        </nav>
      <% end %>

      <!-- Main content -->
      <main class="pt-16 pb-20 sm:pb-0">
        <!-- Flash messages -->
        <div id="flash" role="alert" aria-live="polite">
          <% if notice %>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
              <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-md p-4">
                <div class="flex">
                  <svg class="h-5 w-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <p class="ml-3 text-sm text-green-700 dark:text-green-300"><%= notice %></p>
                </div>
              </div>
            </div>
          <% end %>

          <% if alert %>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
              <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-md p-4">
                <div class="flex">
                  <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <p class="ml-3 text-sm text-red-700 dark:text-red-300"><%= alert %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%= yield %>
      </main>
    <% else %>
      <!-- Unauthenticated layout -->
      <div class="min-h-screen flex items-center justify-center">
        <div class="max-w-md w-full space-y-8">
          <div>
            <div class="mt-6 flex items-center justify-center gap-3">
              <svg class="h-10 w-10" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M 100 35 L 55 55 Q 50 57 50 63 L 50 95 Q 50 130 100 165 Q 150 130 150 95 L 150 63 Q 150 57 145 55 Z" stroke="#2563EB" stroke-width="8" stroke-linejoin="round"/>
                <path d="M 72 105 L 92 125 L 132 80" stroke="#2563EB" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <h2 class="text-3xl font-extrabold text-gray-900 dark:text-gray-100">Pact</h2>
            </div>
            <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
              Sign in or create an account to continue
            </p>
          </div>
          <%= yield %>
        </div>
      </div>
    <% end %>
  </body>
</html>
