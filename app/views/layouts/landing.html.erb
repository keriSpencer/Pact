<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Pact — Document Signing, Simplified" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Pact is the simplest way to send documents for signature and manage your contacts. No per-document fees, no complexity.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#2563EB">
    <meta property="og:image" content="https://pactapp.io/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <%= link_to root_path, class: "flex items-center gap-2 text-xl font-bold text-gray-900 tracking-tight", "aria-label": "Pact Home" do %>
            <svg class="h-7 w-7" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M 100 35 L 55 55 Q 50 57 50 63 L 50 95 Q 50 130 100 165 Q 150 130 150 95 L 150 63 Q 150 57 145 55 Z" stroke="#2563EB" stroke-width="8" stroke-linejoin="round"/>
              <path d="M 72 105 L 92 125 L 132 80" stroke="#2563EB" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Pact
          <% end %>
          <div class="flex items-center gap-6">
            <a href="/#pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
            <%= link_to "Contact", contact_us_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
            <%= link_to "Sign In", new_user_session_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
            <%= link_to "Start Free", new_user_registration_path, class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-colors" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-green-800"><%= notice %></p>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-red-800"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div>
            <span class="flex items-center gap-2 text-lg font-bold text-white">
              <svg class="h-6 w-6" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M 100 35 L 55 55 Q 50 57 50 63 L 50 95 Q 50 130 100 165 Q 150 130 150 95 L 150 63 Q 150 57 145 55 Z" stroke="#60A5FA" stroke-width="8" stroke-linejoin="round"/>
                <path d="M 72 105 L 92 125 L 132 80" stroke="#60A5FA" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Pact
            </span>
            <p class="text-sm text-gray-500 mt-1">Document signing and contact management, simplified.</p>
          </div>
          <div class="flex items-center gap-8">
            <%= link_to "Contact", contact_us_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
            <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-gray-800">
          <p class="text-sm text-gray-600 text-center">&copy; <%= Date.current.year %> Pact. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
