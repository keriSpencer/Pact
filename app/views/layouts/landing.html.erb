<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Pact — Document Signing, Simplified" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Pact is the simplest way to send documents for signature and manage your contacts. No per-document fees, no complexity.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <%= link_to root_path, class: "text-xl font-bold text-gray-900 tracking-tight" do %>
            Pact
          <% end %>
          <div class="flex items-center gap-6">
            <%= link_to "Contact", contact_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" %>
            <%= link_to "Sign In", new_user_session_path, class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-green-800"><%= notice %></p>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex items-center gap-3">
          <svg class="h-5 w-5 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-red-800"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div>
            <span class="text-lg font-bold text-white">Pact</span>
            <p class="text-sm text-gray-500 mt-1">Document signing and contact management, simplified.</p>
          </div>
          <div class="flex items-center gap-8">
            <%= link_to "Contact", contact_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
            <%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-gray-800">
          <p class="text-sm text-gray-600 text-center">&copy; <%= Date.current.year %> Pact. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
