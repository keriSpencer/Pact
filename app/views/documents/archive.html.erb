<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <div class="flex items-center space-x-3 mb-1">
      <%= link_to "Documents", folders_path, class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
      <span class="text-gray-400 dark:text-gray-500">/</span>
      <span class="text-sm text-gray-900 dark:text-gray-100 font-medium">Signed Archive</span>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Signed Archive</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Documents with signed versions that were archived. These are preserved for legal compliance.</p>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <% if @documents.any? %>
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Document</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden sm:table-cell">Signed By</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden md:table-cell">Signed</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden lg:table-cell">Archived</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @documents.each do |doc| %>
            <% signed_versions = doc.versions.select(&:signed?).sort_by(&:created_at).reverse %>
            <% if signed_versions.any? %>
              <% signed_versions.each_with_index do |sv, idx| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                  <td class="px-6 py-4">
                    <% if idx == 0 %>
                      <%= link_to document_path(doc), class: "block" do %>
                        <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= doc.name %></p>
                        <p class="text-xs text-gray-500 dark:text-gray-400"><%= doc.formatted_file_size %></p>
                      <% end %>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden sm:table-cell">
                    <% if sv.signature_request %>
                      <p><%= sv.signature_request.signer_display_name %></p>
                      <p class="text-xs text-gray-500 dark:text-gray-400"><%= sv.signature_request.signer_email %></p>
                    <% else %>
                      <p><%= sv.display_label %></p>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden md:table-cell">
                    <%= sv.signature_request&.signed_at&.strftime("%b %d, %Y") || sv.created_at.strftime("%b %d, %Y") %>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden lg:table-cell">
                    <% if idx == 0 %>
                      <%= doc.updated_at.strftime("%b %d, %Y") %>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <% if sv.file.attached? %>
                      <%= link_to "Download", rails_blob_path(sv.file, disposition: "attachment"), class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium transition-colors" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                <td class="px-6 py-4">
                  <%= link_to document_path(doc), class: "block" do %>
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= doc.name %></p>
                    <p class="text-xs text-gray-500 dark:text-gray-400"><%= doc.formatted_file_size %></p>
                  <% end %>
                </td>
                <td class="px-6 py-4 hidden sm:table-cell"></td>
                <td class="px-6 py-4 hidden md:table-cell"></td>
                <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden lg:table-cell">
                  <%= doc.updated_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 text-right">
                  <% if doc.file.attached? %>
                    <%= link_to "Download Original", rails_blob_path(doc.file, disposition: "attachment"), class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium transition-colors" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No archived documents</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Documents with signatures will appear here when archived.</p>
      </div>
    <% end %>
  </div>
</div>
