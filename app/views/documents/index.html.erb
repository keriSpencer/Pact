<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumbs -->
  <% if @breadcrumbs %>
    <nav class="mb-4 text-sm">
      <%= link_to "Documents", folders_path, class: "text-blue-600 hover:text-blue-800" %>
      <% @breadcrumbs.each do |crumb| %>
        <span class="text-gray-400 mx-1">/</span>
        <%= link_to crumb.name, folder_path(crumb), class: "text-blue-600 hover:text-blue-800" %>
      <% end %>
    </nav>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @page_title || "Documents" %></h1>
    <%= link_to new_document_path(folder_id: @folder&.id), class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" do %>
      Upload Document
    <% end %>
  </div>

  <!-- Search -->
  <div class="mb-6">
    <%= form_with url: documents_path(folder_id: @folder&.id), method: :get, local: true, class: "flex" do |form| %>
      <%= form.text_field :search, value: params[:search], placeholder: "Search documents...", class: "flex-1 max-w-md" %>
      <%= form.submit "Search", class: "ml-3 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer" %>
      <% if params[:search].present? %>
        <%= link_to "Clear", documents_path(folder_id: @folder&.id), class: "ml-2 px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700" %>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow">
    <% if @documents.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden sm:table-cell">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden md:table-cell">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden lg:table-cell">Uploaded</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @documents.each do |doc| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4">
                <%= link_to document_path(doc), class: "block" do %>
                  <p class="text-sm font-medium text-gray-900"><%= doc.name %></p>
                  <% if doc.description.present? %>
                    <p class="text-xs text-gray-500 truncate max-w-xs"><%= doc.description %></p>
                  <% end %>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 hidden sm:table-cell"><%= doc.formatted_file_size %></td>
              <td class="px-6 py-4 text-sm text-gray-500 hidden md:table-cell"><%= doc.file_type_category.capitalize %></td>
              <td class="px-6 py-4 text-sm text-gray-400 hidden lg:table-cell"><%= doc.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No documents</h3>
        <p class="mt-1 text-sm text-gray-500">Upload your first document to get started.</p>
        <div class="mt-6">
          <%= link_to "Upload Document", new_document_path, class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
