<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @contact.full_name %></h1>
      <% if @contact.title.present? || @contact.company.present? %>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          <%= [@contact.title, @contact.company].compact.join(" at ") %>
        </p>
      <% end %>
      <!-- Tags -->
      <% if @contact.tags.any? %>
        <div class="mt-2 flex flex-wrap gap-1">
          <% @contact.tags.each do |tag| %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= tag.bg_class %> <%= tag.text_class %>">
              <%= tag.name %>
              <%= link_to "x", untag_contact_path(@contact, tag_id: tag.id), data: { "turbo-method": "delete" }, class: "ml-1 hover:opacity-70 transition-colors" %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_contact_path(@contact), class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" %>
      <%= link_to "Delete", contact_path(@contact), data: { "turbo-method": "delete", turbo_confirm: "Are you sure you want to delete #{@contact.full_name}?" }, class: "px-4 py-2 text-sm font-medium text-red-600 bg-white dark:bg-gray-700 border border-red-300 dark:border-red-500/50 rounded-md hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Sidebar -->
    <div class="lg:col-span-1 space-y-6">
      <!-- Contact Info -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Contact Information</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
          <div>
            <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Email</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">
              <%= mail_to @contact.email, @contact.email, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
            </dd>
          </div>
          <% if @contact.phone.present? %>
            <div>
              <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Phone</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @contact.phone %></dd>
            </div>
          <% end %>
          <% if @contact.company.present? %>
            <div>
              <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Company</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @contact.company %></dd>
            </div>
          <% end %>
          <% if @contact.title.present? %>
            <div>
              <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Title</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @contact.title %></dd>
            </div>
          <% end %>
          <% if @contact.linkedin_url.present? %>
            <div>
              <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">LinkedIn</dt>
              <dd class="mt-1 text-sm">
                <%= link_to @contact.linkedin_display, @contact.linkedin_url, target: "_blank", rel: "noopener", class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
              </dd>
            </div>
          <% end %>
          <div>
            <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Added</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @contact.created_at.strftime("%B %d, %Y") %></dd>
          </div>
        </div>
      </div>

      <!-- Tags -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Tags</h2>
        </div>
        <div class="px-6 py-4">
          <% available_tags = current_organization.tags.ordered - @contact.tags %>
          <% if available_tags.any? %>
            <div class="flex flex-wrap gap-2">
              <% available_tags.each do |tag| %>
                <%= link_to tag_contact_path(@contact, tag_id: tag.id), data: { "turbo-method": "post" }, class: "inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium #{tag.bg_class} #{tag.text_class} opacity-60 hover:opacity-100 cursor-pointer transition-colors" do %>
                  + <%= tag.name %>
                <% end %>
              <% end %>
            </div>
          <% elsif @contact.tags.empty? %>
            <p class="text-sm text-gray-500 dark:text-gray-400">No tags available. <% if current_user.admin? %><%= link_to "Create tags", tags_path, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %><% end %></p>
          <% else %>
            <p class="text-sm text-gray-500 dark:text-gray-400">All tags applied.</p>
          <% end %>
        </div>
      </div>

      <!-- Assignments -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Assigned To</h2>
        </div>
        <div class="px-6 py-4">
          <% if @contact.assigned_users.any? %>
            <div class="space-y-3">
              <% @contact.assigned_users.each do |user| %>
                <div class="flex items-center">
                  <div class="h-8 w-8 rounded-full bg-blue-600 flex items-center justify-center">
                    <span class="text-xs font-medium text-white"><%= user.initials %></span>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= user.full_name %></p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-amber-600">No one assigned</p>
          <% end %>
          <% if current_user.admin? %>
            <details class="mt-4 group">
              <summary class="text-sm text-blue-600 dark:text-blue-400 cursor-pointer hover:text-blue-800 dark:hover:text-blue-300 transition-colors flex items-center">
                <svg class="h-4 w-4 mr-1 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
                Update assignments
              </summary>
              <%= form_with url: assign_contact_path(@contact), method: :patch, class: "mt-3 space-y-2" do %>
                <% current_organization.users.order(:first_name).each do |user| %>
                  <label class="flex items-center cursor-pointer">
                    <input type="checkbox" name="user_ids[]" value="<%= user.id %>" class="mr-2"
                           <%= "checked" if @contact.assigned_users.include?(user) %>>
                    <span class="text-sm text-gray-700 dark:text-gray-300"><%= user.full_name %></span>
                  </label>
                <% end %>
                <button type="submit" class="mt-2 px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer" data-turbo-submits-with="Saving...">Save</button>
              <% end %>
            </details>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Documents & Signatures -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Documents & Signatures</h2>
          <details class="group relative">
            <summary class="px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer list-none flex items-center">
              Send for Signature
              <svg class="h-3 w-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="absolute right-0 sm:right-0 left-0 sm:left-auto mt-2 w-auto sm:w-72 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg z-10 p-4">
              <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Select a document to send to <strong><%= @contact.full_name %></strong>:</p>
              <% pdf_docs = current_organization.documents.active.where(content_type: "application/pdf").order(:name) %>
              <% if pdf_docs.any? %>
                <div class="space-y-1 max-h-48 overflow-y-auto">
                  <% pdf_docs.each do |doc| %>
                    <%= link_to new_document_signature_request_path(doc, signer_email: @contact.email, signer_name: @contact.full_name),
                        class: "block px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600 rounded-md transition-colors" do %>
                      <span class="font-medium"><%= doc.name %></span>
                      <span class="text-xs text-gray-400 block"><%= doc.formatted_file_size %></span>
                    <% end %>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">No PDF documents uploaded yet.</p>
                <%= link_to "Upload a document", new_document_path, class: "text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 transition-colors" %>
              <% end %>
            </div>
          </details>
        </div>

        <% if @signature_requests.any? %>
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @signature_requests.each do |sr| %>
              <div class="px-6 py-3 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                <div>
                  <% if sr.document %>
                    <%= link_to sr.document.name, document_path(sr.document), class: "text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
                  <% end %>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <% if sr.signed? %>
                      Signed <%= time_ago_in_words(sr.signed_at) %> ago
                    <% elsif sr.sent? || sr.viewed? || sr.pending? %>
                      Sent <%= time_ago_in_words(sr.sent_at || sr.created_at) %> ago
                    <% else %>
                      <%= sr.status.humanize %> — <%= time_ago_in_words(sr.created_at) %> ago
                    <% end %>
                  </p>
                </div>
                <span class="text-xs px-2 py-1 rounded-full <%= sr.status_color_class %>"><%= sr.status.humanize %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No signature requests yet</p>
          </div>
        <% end %>
      </div>

      <!-- Add Note Form -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Add Note</h2>
        </div>
        <%= form_with(model: ContactNote.new, url: contact_contact_notes_path(@contact), method: :post, class: "px-6 py-4 space-y-4") do |form| %>
          <div class="flex space-x-4">
            <div class="w-40">
              <%= form.select :contact_type, ContactNote::CONTACT_TYPES, { include_blank: "Type..." }, class: "block w-full text-sm" %>
            </div>
            <div class="flex-1">
              <%= form.date_field :follow_up_date, class: "block w-full text-sm", placeholder: "Follow-up date" %>
            </div>
          </div>
          <%= form.text_area :note, rows: 3, class: "block w-full text-sm", placeholder: "Write a note..." %>
          <div class="flex justify-end">
            <%= form.submit "Add Note", class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors cursor-pointer", data: { turbo_submits_with: "Adding..." } %>
          </div>
        <% end %>
      </div>

      <!-- Notes Timeline -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider">Notes (<%= @contact.contact_notes.count %>)</h2>
        </div>
        <% notes = @contact.contact_notes.recent.includes(:user) %>
        <% if notes.any? %>
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            <% notes.each do |note| %>
              <div class="px-6 py-4">
                <div class="flex justify-between items-start">
                  <div class="flex items-center space-x-2">
                    <% if note.user %>
                      <div class="h-6 w-6 rounded-full bg-blue-600 flex items-center justify-center">
                        <span class="text-xs font-medium text-white"><%= note.user.initials %></span>
                      </div>
                      <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= note.user.full_name %></span>
                    <% end %>
                    <% if note.contact_type.present? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                        <%= note.contact_type_display %>
                      </span>
                    <% end %>
                    <span class="text-xs text-gray-500 dark:text-gray-400"><%= time_ago_in_words(note.contacted_at) %> ago</span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <%= link_to "Edit", edit_contact_contact_note_path(@contact, note), class: "text-xs text-gray-500 dark:text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" %>
                    <%= link_to "Delete", contact_contact_note_path(@contact, note), data: { "turbo-method": "delete", turbo_confirm: "Delete this note?" }, class: "text-xs text-red-500 hover:text-red-600 transition-colors" %>
                  </div>
                </div>
                <p class="mt-2 text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= note.note %></p>
                <% if note.follow_up_date.present? %>
                  <div class="mt-2 flex items-center space-x-2">
                    <% if note.follow_up_completed? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                        Follow-up completed
                      </span>
                    <% elsif note.follow_up_overdue? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                        <%= note.follow_up_display %>
                      </span>
                      <%= link_to "Complete", complete_follow_up_contact_contact_note_path(@contact, note), data: { "turbo-method": "patch" }, class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                        Follow up: <%= note.follow_up_display %>
                      </span>
                      <%= link_to "Complete", complete_follow_up_contact_contact_note_path(@contact, note), data: { "turbo-method": "patch" }, class: "text-xs text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No notes yet</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Add your first note above to start tracking interactions.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
