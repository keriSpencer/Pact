<%= turbo_stream.replace "share_link_section" do %>
  <div id="share_link_section">
    <details class="relative inline-block" open>
      <summary class="px-3 py-1.5 text-sm font-medium text-green-700 dark:text-green-300 bg-green-50 dark:bg-green-900/30 border border-green-300 dark:border-green-700 rounded-md hover:bg-green-100 dark:hover:bg-green-900/50 transition-colors cursor-pointer list-none">
        Shared
      </summary>
      <div class="absolute left-0 mt-2 w-80 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg z-20 p-3" data-controller="clipboard">
        <div class="flex items-center gap-2">
          <input type="text" value="<%= @share.share_url %>" readonly
                 class="flex-1 text-xs bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded px-2 py-1.5 text-gray-700 dark:text-gray-200 focus:ring-0 truncate"
                 data-clipboard-target="source">
          <button type="button" data-action="clipboard#copy" data-clipboard-target="button"
                  class="px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded hover:bg-blue-700 transition-colors cursor-pointer whitespace-nowrap">
            Copy
          </button>
        </div>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
          Anyone with this link can view. Expires <%= @share.expires_at.strftime("%b %d, %Y") %>.
        </p>
        <div class="mt-2 pt-2 border-t border-gray-200 dark:border-gray-700">
          <%= link_to "Unshare", document_document_share_path(@document, @share),
                data: { "turbo-method": "delete", turbo_confirm: "This will disable the share link. Anyone with it will lose access." },
                class: "text-xs text-red-500 hover:text-red-700 dark:text-red-400 transition-colors" %>
        </div>
      </div>
    </details>
  </div>
<% end %>
