<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-xl font-bold text-red-600">Delete Folder</h1>
    </div>
    <div class="px-6 py-5 space-y-4">
      <p class="text-sm text-gray-700 dark:text-gray-300">
        Are you sure you want to delete <strong><%= @folder.name %></strong>?
      </p>

      <% if @folder.has_contents? %>
        <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-800 rounded-md p-4">
          <div class="flex">
            <svg class="h-5 w-5 text-amber-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            </svg>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-amber-800 dark:text-amber-300">This folder contains <%= @folder.contents_summary %></h3>
              <p class="mt-1 text-sm text-amber-700 dark:text-amber-400">
                Documents will be moved to <strong>Unfiled</strong> and can still be accessed. The folder can be restored later if needed.
              </p>
            </div>
          </div>
        </div>

        <% if @folder.documents.any? %>
          <div class="border border-gray-200 dark:border-gray-700 rounded-md">
            <div class="px-4 py-2 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Documents that will be unfiled</h3>
            </div>
            <ul class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @folder.documents.limit(10).each do |doc| %>
                <li class="px-4 py-2 text-sm text-gray-700 dark:text-gray-300"><%= doc.name %></li>
              <% end %>
              <% remaining = @folder.documents.count - 10 %>
              <% if remaining > 0 %>
                <li class="px-4 py-2 text-sm text-gray-500 dark:text-gray-400 italic">and <%= remaining %> more...</li>
              <% end %>
            </ul>
          </div>
        <% end %>
      <% end %>

      <div class="flex justify-end space-x-3 pt-4">
        <%= link_to "Cancel", folder_path(@folder), class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" %>
        <%= link_to "Delete Folder", folder_path(@folder), data: { "turbo-method": "delete" }, class: "px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-md hover:bg-red-700 transition-colors" %>
      </div>
    </div>
  </div>
</div>
