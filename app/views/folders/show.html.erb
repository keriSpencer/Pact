<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Breadcrumbs -->
  <nav class="mb-4 text-sm">
    <%= link_to "Documents", folders_path, class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
    <% @breadcrumbs.each do |crumb| %>
      <span class="text-gray-400 dark:text-gray-500 mx-1">/</span>
      <% if crumb == @folder %>
        <span class="text-gray-900 dark:text-gray-100 font-medium"><%= crumb.name %></span>
      <% else %>
        <%= link_to crumb.name, folder_path(crumb), class: "text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" %>
      <% end %>
    <% end %>
  </nav>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100"><%= @folder.name %></h1>
      <% if @folder.description.present? %>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= @folder.description %></p>
      <% end %>
    </div>
    <div class="flex space-x-3">
      <%= link_to new_folder_path(parent_id: @folder.id), class: "px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors" do %>
        New Subfolder
      <% end %>
      <%= link_to new_document_path(folder_id: @folder.id), class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors" do %>
        Upload
      <% end %>
      <%= link_to "Edit", edit_folder_path(@folder), class: "px-3 py-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors" %>
      <%= link_to "Delete", confirm_delete_folder_path(@folder), class: "px-3 py-2 text-sm text-red-500 hover:text-red-700 transition-colors" %>
    </div>
  </div>

  <!-- Subfolders -->
  <% if @subfolders.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      <% @subfolders.each do |subfolder| %>
        <%= link_to folder_path(subfolder), class: "bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 hover:shadow-md transition-shadow flex items-center" do %>
          <div class="h-10 w-10 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center mr-3">
            <svg class="h-5 w-5 text-blue-500 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= subfolder.name %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= subfolder.document_count %> documents</p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Documents -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
    <% if @documents.any? %>
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden sm:table-cell">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden md:table-cell">Uploaded</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @documents.each do |doc| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
              <td class="px-6 py-4">
                <%= link_to document_path(doc), class: "block" do %>
                  <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= doc.name %></p>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= doc.content_type %></p>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden sm:table-cell"><%= doc.formatted_file_size %></td>
              <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden md:table-cell"><%= doc.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-6 py-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">No documents</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">No documents in this folder yet.</p>
        <div class="mt-6">
          <%= link_to "Upload Document", new_document_path(folder_id: @folder.id), class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
